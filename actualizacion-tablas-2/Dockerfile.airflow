FROM apache/airflow:2.10.3-python3.12

# Install app-specific dependencies on top of the base Airflow image.
# The Airflow image already contains apache-airflow and its core deps;
# we only need to add what our ETL code requires.
USER airflow
COPY requirements.txt /tmp/requirements.txt
RUN pip install --no-cache-dir -r /tmp/requirements.txt
